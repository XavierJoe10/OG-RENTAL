// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  TENANT
  ADMIN
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum AgreementStatus {
  PENDING
  ACTIVE
  TERMINATED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role
  walletAddress String?  @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  properties         Property[]
  offers             Offer[]
  agreementsAsOwner  Agreement[] @relation("OwnerAgreements")
  agreementsAsTenant Agreement[] @relation("TenantAgreements")
  paymentsAsTenant   Payment[]   @relation("TenantPayments")
  paymentsAsOwner    Payment[]   @relation("OwnerPayments")
}

model Property {
  id          String   @id @default(cuid())
  title       String
  description String
  location    String
  price       Float
  bedrooms    Int
  bathrooms   Int
  areaSqFt    Float?
  isAvailable Boolean  @default(true)

  imageCIDs   String[]
  videoCIDs   String[]

  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])

  offers      Offer[]
  agreements  Agreement[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Offer {
  id         String      @id @default(cuid())
  price      Float
  message    String?
  status     OfferStatus @default(PENDING)

  propertyId String
  property   Property    @relation(fields: [propertyId], references: [id])

  tenantId   String
  tenant     User        @relation(fields: [tenantId], references: [id])

  agreement  Agreement?

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Agreement {
  id              String          @id @default(cuid())
  monthlyRent     Float
  startDate       DateTime
  endDate         DateTime
  ipfsCID         String
  onChainId       Int?
  txHash          String?
  status          AgreementStatus @default(ACTIVE)

  propertyId      String
  property        Property        @relation(fields: [propertyId], references: [id])

  ownerId         String
  owner           User            @relation("OwnerAgreements", fields: [ownerId], references: [id])

  tenantId        String
  tenant          User            @relation("TenantAgreements", fields: [tenantId], references: [id])

  offerId         String?         @unique
  offer           Offer?          @relation(fields: [offerId], references: [id])

  payments        Payment[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Payment {
  id            String        @id @default(cuid())
  amount        Float
  month         String                              // "2025-03"
  status        PaymentStatus @default(PENDING)
  upiId         String?
  transactionId String        @unique

  agreementId   String
  agreement     Agreement     @relation(fields: [agreementId], references: [id])

  tenantId      String
  tenant        User          @relation("TenantPayments", fields: [tenantId], references: [id])

  ownerId       String
  owner         User          @relation("OwnerPayments",  fields: [ownerId],  references: [id])

  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}
